# Copy to .env and fill in your values. Never commit .env.

# LINE Creators Market
LINE_EMAIL=
LINE_PASSWORD=
LINE_CREATOR_ID=
LINE_STICKER_ID=

# Google Drive (可確認作品的網址)
GOOGLE_EMAIL=
GOOGLE_PASSWORD=
GDRIVE_PARENT_FOLDER=LINE-sticker
GDRIVE_SET_FOLDER=
GDRIVE_STICKER_SUBFOLDER=sticker-pack
GDRIVE_FOLDER_ID=
GDRIVE_SHARE_URL=

# Sticker text
STICKER_TITLE_ZH=
STICKER_DESC_ZH=
STICKER_TITLE_EN=
STICKER_DESC_EN=

# Form defaults: USE_AI=true|false, SALE_START=auto|manual
COPYRIGHT=Copyright (c) YourBrand
USE_AI=true
SALE_START=auto
STICKER_COUNT=40
SALE_REGION=all
JOIN_CAMPAIGNS=false

# Paths — upload_line_zip.py defaults to upload-ready.zip at repo root; use --zip for any path.
# If LINE accepts line-stickers-pack.zip as-is (e.g. nested sticker-pack/), pass that file — no flatten required.
SOURCE_ZIP=line-stickers-pack.zip
UPLOAD_ZIP=upload-ready.zip
SPRITE_SHEETS_DIR=sprite_sheets
