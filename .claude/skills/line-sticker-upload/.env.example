# LEGACY: single-file mode for running Python scripts directly without batch env.
# Preferred setup:
#   1. credentials.env  — account secrets (see line-sticker-maker/credentials.env.example)
#   2. <out>/.env.batch/*.env — per-set metadata + paths (auto-generated by finalize/sync)
#   3. run-line-upload.mts merges (1) into (2) before each step
#
# Copy to .env only if you need one self-contained file for manual debugging.

# --- Account (normally in credentials.env) ---
LINE_EMAIL=
LINE_PASSWORD=
LINE_CREATOR_ID=

# --- Per-set runtime (normally in .env.batch) ---
LINE_STICKER_ID=

GOOGLE_EMAIL=
GOOGLE_PASSWORD=
GDRIVE_PARENT_FOLDER=LINE-sticker
GDRIVE_SET_FOLDER=
GDRIVE_STICKER_SUBFOLDER=sticker-pack
GDRIVE_FOLDER_ID=
GDRIVE_SHARE_URL=

STICKER_TITLE_ZH=
STICKER_DESC_ZH=
STICKER_TITLE_EN=
STICKER_DESC_EN=

COPYRIGHT=Copyright (c) YourBrand
USE_AI=true
SALE_START=auto
STICKER_COUNT=40
SALE_REGION=all
JOIN_CAMPAIGNS=false

SOURCE_ZIP=line-stickers-pack.zip
UPLOAD_ZIP=upload-ready.zip
SPRITE_SHEETS_DIR=sprite_sheets
