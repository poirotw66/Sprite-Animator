# Copy to credentials.env (gitignored). One file for all sticker sets on this machine.
#
# LINE_CREATOR_ID = Creators Market account ID from URL:
#   https://creator.line.me/my/{LINE_CREATOR_ID}/...
# LINE_STICKER_ID is NOT set here — provision writes it into each <out>/.env.batch/*.env

LINE_EMAIL=
LINE_PASSWORD=
LINE_CREATOR_ID=

GOOGLE_EMAIL=
GOOGLE_PASSWORD=
GDRIVE_PARENT_FOLDER=LINE-sticker
